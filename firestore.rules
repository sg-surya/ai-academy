rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // catch-all default deny rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }

    function isValidRegistration(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'role', 'reason', 'timestamp'])
        && data.keys().size() == 6
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.email is string && data.email.size() > 0 && data.email.size() <= 200
        && data.phone is string && data.phone.size() > 0 && data.phone.size() <= 50
        && data.role is string && data.role.size() > 0 && data.role.size() <= 100
        && data.reason is string && data.reason.size() <= 2000
        && data.timestamp is string && data.timestamp.size() <= 100;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'city', 'rating', 'enjoyed', 'improve', 'recommend', 'futureTopics', 'timestamp'])
        && data.keys().size() == 10
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.email is string && data.email.size() > 0 && data.email.size() <= 200
        && data.phone is string && data.phone.size() > 0 && data.phone.size() <= 50
        && data.city is string && data.city.size() > 0 && data.city.size() <= 200
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.enjoyed is string && data.enjoyed.size() <= 2000
        && data.improve is string && data.improve.size() <= 2000
        && data.recommend is string && data.recommend.size() > 0 && data.recommend.size() <= 50
        && data.futureTopics is string && data.futureTopics.size() <= 2000
        && data.timestamp is string && data.timestamp.size() <= 100;
    }

    function isValidCertificate(data) {
      return data.keys().hasAll(['name', 'workshop', 'date', 'issuer', 'status'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.workshop is string && data.workshop.size() > 0 && data.workshop.size() <= 300
        && data.date is string && data.date.size() > 0 && data.date.size() <= 50
        && data.issuer is string && data.issuer.size() > 0 && data.issuer.size() <= 200
        && data.status is string && data.status == 'Verified';
    }

    function isValidWaitlistEntry(data) {
      return data.keys().hasAll(['name', 'email', 'interestedIn', 'cohort', 'timestamp'])
        && data.keys().size() == 5
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.email is string && data.email.size() > 0 && data.email.size() <= 200
        && data.interestedIn is string && data.interestedIn.size() > 0 && data.interestedIn.size() <= 100
        && data.cohort is string && data.cohort.size() > 0 && data.cohort.size() <= 200
        && data.timestamp is string && data.timestamp.size() > 0 && data.timestamp.size() <= 100;
    }

    function isValidCohort2TopicVote(data) {
      return data.keys().hasAll(['topic', 'cohort', 'timestamp'])
        && data.keys().size() == 3
        && data.topic is string
        && data.topic in ['Vibe Coding (Build Apps & Websites with AI)', 'AI Agents', 'AI Automation', 'Advanced Prompt Engineering', 'AI for Business & Marketing', 'Something Else']
        && data.cohort is string && data.cohort == 'Cohort #02 - Build With AI'
        && data.timestamp is string && data.timestamp.size() > 0 && data.timestamp.size() <= 100;
    }

    // Registrations rules
    match /registrations/{registrationId} {
      allow create: if isValidId(registrationId) && isValidRegistration(incoming());
      allow read, update, delete: if false;
    }

    // Reviews rules
    match /reviews/{reviewId} {
      allow create: if isValidId(reviewId) && isValidReview(incoming());
      allow read, update, delete: if false;
    }

    // Certificates — public read for verification, admin-only write
    match /certificates/{certId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // Waitlist — public create for signups
    match /waitlist/{entryId} {
      allow create: if isValidWaitlistEntry(incoming());
      allow read, update, delete: if false;
    }

    // Cohort #02 topic poll — public create/read for live percentages
    match /cohort_2_topic_votes/{voteId} {
      allow create: if isValidCohort2TopicVote(incoming());
      allow read: if true;
      allow update, delete: if false;
    }
  }
}
